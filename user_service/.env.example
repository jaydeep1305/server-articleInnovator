# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=true
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/user_service_dev
DEV_DATABASE_URL=postgresql://user:password@localhost:5432/user_service_dev
TEST_DATABASE_URL=postgresql://user:password@localhost:5432/user_service_test

# Security Keys (CHANGE IN PRODUCTION!)
SECRET_KEY=dev-secret-key-change-in-production
JWT_SECRET_KEY=jwt-secret-key-change-in-production

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Email Configuration (for production)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Logging
LOG_LEVEL=DEBUG

# API Configuration
API_VERSION=v1

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60