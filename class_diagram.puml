@startuml Article Innovator Class-Based Components

!theme plain
skinparam backgroundColor white
skinparam classBackgroundColor white  
skinparam classBorderColor black

package "Middleware Classes" {
    class AccessControlMiddleware {
        +get_response: callable
        +jwt_authenticator: JWTAuthentication
        --
        +__init__(get_response)
        +__call__(request): HttpResponse
        +authenticate_user(request): tuple
    }

    class RateLimitMiddleware {
        +RATE_LIMIT: int = 1000
        +TIME_WINDOW: int = 60
        +BAN_DURATION: int = 86400
        +get_response: callable
        --
        +__init__(get_response)
        +__call__(request): HttpResponse
    }

    class ActivityLogMiddleware {
        +get_response: callable
        --
        +__init__(get_response)
        +__call__(request): HttpResponse
        +process_request(request): void
        +process_response(request, response): HttpResponse
    }
}

package "Service Classes" {
    class ImageGenerator {
        --
        +get_all_templates_by_tags(json_data): dict
        +create_circular_templates_info(templates_info, number): list
        +create_circular_keywords(keyword_with_original_image_url, template_image_count): list
        +upload_image_to_imagekit(original_image_url, keyword, workspace_id): string
        +get_imagekit_urls(keyword, original_image_url, workspace_id): string
        +generate_image(template_file_name): string
        +process_template(template, keyword_with_original_image_url, used_orignal_image_url, workspace_id): string
        +process_template_done(generated_images): callable
    }

    class AIProvider {
        +api_key: string
        +api_url: string
        +model: string
        +client: OpenAI
        --
        +__init__()
        +extract_selectors(html_content, domain): dict
        -_get_fallback_selectors(): dict
    }
}

package "Utility Classes" {
    class Handler {
        --
        +__init__()
        +log_to_database(message): void
    }
}

package "Configuration Classes" {
    class ApiappConfig {
        +default_auto_field: string
        +name: string
        --
        +ready(): void
    }

    class FrontendappConfig {
        +default_auto_field: string
        +name: string
        --
        +ready(): void
    }
}

' Relationships
AccessControlMiddleware --> RateLimitMiddleware : middleware chain
ActivityLogMiddleware --> Handler : logging
ImageGenerator --> AIProvider : AI processing

@enduml
